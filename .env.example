# Public site URL (used in robots.txt, sitemap, etc.)
# On Vercel: set this in Project Settings → Environment Variables
NEXT_PUBLIC_SITE_URL=https://app.ourhardy.com

# Script helper — passed inline when running scripts/clear-cache.ts
APP_URL=https://app.ourhardy.com

# AWS (S3 / CloudFront)
AWS_REGION=us-west-2
# Local dev: use a named AWS profile (avoids committing keys)
AWS_PROFILE=yourprofile
# Production (Vercel): use static keys instead of AWS_PROFILE
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Neon Postgres — create at neon.tech, connect via Vercel integration
POSTGRES_URL=postgresql://...

# Google SMTP — Gmail account with 2FA + App Password
# (Google Account → Security → 2-Step Verification → App Passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=you@gmail.com

# Auth
ADMIN_EMAIL=you@example.com
SESSION_SECRET=
